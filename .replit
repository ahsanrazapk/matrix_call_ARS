modules = ["ruby-3.2", "swift-5.8", "dart-3.10", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash run.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "export PATH=/home/runner/flutter/bin:$PATH && flutter build web --release"]
publicDir = "build/web"

[[ports]]
localPort = 5000
externalPort = 80
